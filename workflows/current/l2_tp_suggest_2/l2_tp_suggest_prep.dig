timezone: Asia/Tokyo

_export: 
  td:
    database: l2_tp_suggest

+load:
  _parallel: true
  +time_slot_detail:
    require>: ms_l0_proc_ingest_core_ss_4
    project_name: mysql_ingest_preprocess
    session_time: ${moment(session_time).format()}
    rerun_on: all
  +quest:
    require>: rs_l0_proc_ingest_sys_ss
    project_name: redshift_ingest_preprocess
    session_time: ${moment(session_time).format()}
    rerun_on: all

+prep:
  td>: cls_sufficiency_current.sql

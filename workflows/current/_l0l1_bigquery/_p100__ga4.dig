### main process ###
# 初回実行用にテーブルが存在しない場合は作成
# +initialize_tables:
#   if>: ${is_initial}
#   _do:
#     td_ddl>:
#     empty_tables: ["firebase_event_log"]
#   _else_do:
#     td_ddl>:
#     create_tables: ["firebase_event_log"]

# 日次更新、再実行用に取得する予定のtimeに該当するレコードを削除
+delete_duplicate_records:
  +app_pv_log:
    td>:
    query: |
      delete from firebase_event_log
      where time between ${moment(date_from).unix()} and ${moment(date_to).unix()}

# データの取得
+load_from_bq:
  # _parallel: true
  # app_pv_logのうちcontent_view: コンテンツの閲覧を1行にまとめて取得
  td_for_each>: __func_/date_trunc_list.sql
  _parallel: true
  _do:
    td_load>: p100_/firebase_event_log.yml
    table: firebase_event_log
    date_from: ${td.each.date_from}
    date_to: ${td.each.date_to} # 終点含む

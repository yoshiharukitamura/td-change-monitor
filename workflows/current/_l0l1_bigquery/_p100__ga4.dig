### Secret Requirement in this Workflow ###
## bq.json_key
#     Need to use "Import Large Dataset"
#         https://docs.treasuredata.com/articles/#!int/google-bigquery-import-integration/a/h1__351679846
#     Required permissions
#         bigquery.tables.export
#         bigquery.tables.delete
#         storage.buckets.get
#         storage.objects.list
#         storage.objects.create
#         storage.objects.delete
#         storage.objects.get
#     Minimum IAM roles
#         BigQuery Data Editor
#         Storage Legacy Bucket Writer
#         Storage Legacy Object Reader

### Timezone Setting ###
timezone: Asia/Tokyo

### Variables ###
_export:
  ## Output Database
  td:
    database: _l0_bigquery
  ## GCP common variables
  gcp:
    project_id: riraku-app-2d95e
    dataset: 
    temp_dataset: 
    gcs_bucket: 
    gcs_path_prefix: hiveiq/
  ## Given by source workflow
  # date_from: YYYY-MM-DD
  # date_to: YYYY-MM-DD
  # split: 
  # is_initial: true or false

### error handling ###

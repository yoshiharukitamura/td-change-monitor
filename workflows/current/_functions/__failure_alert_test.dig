###############################################################
# タイムゾーンの設定と変数の定義
###############################################################
timezone: Asia/Tokyo


###############################################################
# エラー発生時の通知
###############################################################
_error:
  require>: __failure_alert
  # project_name: functions *** テスト用で同一プロジェクトのためコメントアウト
  session_time: ${moment(session_date).format()}
  rerun_on: all
  params:
    failure_session_id: ${session_id}
    ## default false. Set true only for usage
    notify: {mail: false, slack: true, teams: false}


###############################################################
# ワークフローの処理
###############################################################
### 通知のため強制的にエラーにする
+fail:
  fail>:

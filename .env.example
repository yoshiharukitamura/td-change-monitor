# Runtime
APP_ENV=local
LOG_LEVEL=INFO
DISPLAY_TIMEZONE=Asia/Tokyo
AUDIT_LOG_LAG_MINUTES=10
AUDIT_LOG_OVERLAP_MINUTES=30
MAX_CHANGED_TABLES_PER_RUN=250
PROCESSED_ID_RETENTION_DAYS=7
LOCAL_LOG_RETENTION_DAYS=30
MAX_GENERATED_FILE_SIZE_MB=5
HTTP_CONNECT_TIMEOUT_SECONDS=10
HTTP_READ_TIMEOUT_SECONDS=60
HTTP_MAX_RETRIES=3

# Treasure Data
TD_API_BASE_URL=https://api.treasuredata.com/v3
TD_API_KEY=replace_me
TD_QUERY_ENGINE=presto
TD_AUDIT_DATABASE=td_audit_log
TD_AUDIT_TABLE=access
TD_AUDIT_ID_COLUMN=id
TD_AUDIT_TIME_COLUMN=time
TD_AUDIT_EVENT_COLUMN=event_name
TD_AUDIT_EVENT_RESULT_COLUMN=event_result
TD_AUDIT_RESOURCE_NAME_COLUMN=resource_name
TD_AUDIT_RESOURCE_ID_COLUMN=resource_id
TD_AUDIT_REQUEST_PATH_COLUMN=requested_path_info
TD_AUDIT_REQUEST_HTTP_VERB_COLUMN=requested_http_verb
TD_AUDIT_USER_COLUMN=user_email
TD_AUDIT_SOURCE_USER_COLUMN=source_user_email
TD_AUDIT_ATTRIBUTE_COLUMN=attribute_name
TD_AUDIT_OLD_VALUE_COLUMN=old_value
TD_AUDIT_NEW_VALUE_COLUMN=new_value
TD_AUDIT_TARGET_RESOURCE_NAME_COLUMN=target_resource_name
TD_AUDIT_TIME_UNIT=epoch_seconds

# Local Git repository
GIT_REPOSITORY_PATH=.
GIT_REMOTE_NAME=origin
GIT_BRANCH=main
GIT_EXECUTABLE=git
GIT_COMMITTER_NAME=TD Change Monitor
GIT_COMMITTER_EMAIL=td-change-monitor@example.com
GITHUB_REPOSITORY_URL=https://github.com/replace_me/td-change-monitor

# Backlog
BACKLOG_BASE_URL=https://example.backlog.com
BACKLOG_API_KEY=replace_me
BACKLOG_PROJECT_ID=0
BACKLOG_ISSUE_TYPE_ID=0
BACKLOG_PRIORITY_ID=3
BACKLOG_ASSIGNEE_ID=
BACKLOG_CATEGORY_IDS=
